history.scrollRestoration = "manual";
gsap.registerPlugin(ScrollTrigger);

/* --------------------------------------------------
   FULLSCREEN → HARD RESET (handled by single handler later)
-------------------------------------------------- */

let fullscreenReloadTimer = null;

/* restore scroll after reload */
window.addEventListener("load", () => {
  const savedScroll = sessionStorage.getItem("fullscreen_scroll_pos");

  if (savedScroll !== null) {

    requestAnimationFrame(() => {
      requestAnimationFrame(() => {
        window.scrollTo(0, parseInt(savedScroll, 10));

        sessionStorage.removeItem("fullscreen_scroll_pos");

        // IMPORTANT: re-sync GSAP after scroll restore
        ScrollTrigger.refresh();

        // Initialize AOS after GSAP has been refreshed so animations align with layout
        if (typeof AOS !== 'undefined') {
          AOS.init({
            duration: 800,
            once: false,
            easing: 'ease-out-cubic'
          });
          AOS.refresh();
        }
      });
    });

  } else {
    // If nothing to restore still initialize AOS after full load
    if (typeof AOS !== 'undefined') {
      AOS.init({
        duration: 800,
        once: false,
        easing: 'ease-out-cubic'
      });
      AOS.refresh();
    }
  }
});

ScrollTrigger.config({
  ignoreMobileResize: true
});

/* --------------------------------------------------
   HERO SLIDER (SIMPLIFIED + STABLE)
-------------------------------------------------- */

const track = document.querySelector(".image-track");
const images = gsap.utils.toArray(".bg-image");

let heroTrigger;

function getDistance() {
  if (!track) return 0;
  return Math.max(0, track.scrollWidth - window.innerWidth);
}

function setupHero() {
  if (!track) return;

  if (heroTrigger) heroTrigger.kill();

  gsap.set(track, { x: 0 });

  heroTrigger = ScrollTrigger.create({
    trigger: ".hero",
    start: "top top",
    end: () => "+=" + getDistance(),
    pin: true,
    scrub: 1.2,
    invalidateOnRefresh: true,

    onUpdate: (self) => {
      gsap.set(track, {
        x: -getDistance() * self.progress
      });
    }
  });

  images.forEach((img, i) => {
    const depth = (i + 1) * 6;

    ScrollTrigger.create({
      trigger: ".hero",
      start: "top top",
      end: () => "+=" + getDistance(),
      scrub: 1.2,

      onUpdate: (self) => {
        const offset = gsap.utils.mapRange(
          0,
          1,
          0,
          depth,
          self.progress
        );

        gsap.set(img, {
          xPercent: -offset
        });
      }
    });
  });
}

setupHero();

