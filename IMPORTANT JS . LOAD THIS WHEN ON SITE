/* --------------------------------------------------
   WEBSITE PARALLAX
-------------------------------------------------- */

gsap.utils.toArray(".website-content").forEach((section) => {
  const img = section.querySelector(".mountain-bg");
  if (!img) return;

  gsap.to(img, {
    y: 80,
    ease: "none",
    scrollTrigger: {
      trigger: section,
      start: "top bottom",
      end: "bottom top",
      scrub: true
    }
  });
});

/* --------------------------------------------------
   BACKGROUND PARALLAX
-------------------------------------------------- */

gsap.to(".parallax-container", {
  backgroundSize: "190%",
  backgroundPosition: "center 40%",
  ease: "none",
  scrollTrigger: {
    trigger: ".sticky-track",
    start: "top top",
    end: "bottom top",
    scrub: 1.5
  }
});

/* --------------------------------------------------
   SLIDES TIMELINE
-------------------------------------------------- */

const slides = gsap.utils.toArray(
  ".slide-one-container, .slide-two-container, .slide-three-container"
);

const parallaxTextBox = document.querySelector(".parallax-text-box");

const tl = gsap.timeline({
  scrollTrigger: {
    trigger: ".sticky-track",
    pin: true,
    scrub: 1,
    start: "top top",
    end: () => "+=" + (slides.length * 1000),
    invalidateOnRefresh: true
  }
});

if (parallaxTextBox) {
  tl.to(parallaxTextBox, {
    opacity: 0,
    yPercent: -100,
    ease: "power2.in"
  });
}

slides.forEach((slide, i) => {
  tl.to(slide, {
    y: 0,
    ease: "none"
  }, i * 0.5);
});

tl.to(".parallax-container", {
  backgroundSize: "220%",
  opacity: 0,
  duration: 1
}, "-=0.03");

/* --------------------------------------------------
   PROCESS SCROLLER
-------------------------------------------------- */

const processScroller = document.querySelector(".process-scroller");
const fill = document.querySelector(".scroll-fill");
const dot = document.querySelector(".scroll-dot");

let target = 0;
let current = 0;

if (processScroller && fill && dot) {

  processScroller.addEventListener("scroll", () => {
    const max = processScroller.scrollWidth - processScroller.clientWidth;
    if (max > 0) {
      target = processScroller.scrollLeft / max;
    }
  });

  function animate() {
    const max = processScroller.scrollWidth - processScroller.clientWidth;

    if (max > 0) {
      current += (target - current) * 0.08;

      gsap.set(fill, { width: `${current * 100}%` });
      gsap.set(dot, { x: current * 140 });
    }

    requestAnimationFrame(animate);
  }

  animate();

  processScroller.addEventListener(
    "wheel",
    (e) => {
      const max =
        processScroller.scrollWidth - processScroller.clientWidth;

      if (max <= 0) return;

      const atStart = processScroller.scrollLeft <= 0;
      const atEnd = processScroller.scrollLeft >= max;

      if ((atStart && e.deltaY < 0) || (atEnd && e.deltaY > 0)) {
        e.preventDefault();

        gsap.to(processScroller, {
          scrollLeft:
            processScroller.scrollLeft + e.deltaY * 0.25,
          duration: 0.6,
          ease: "power3.out"
        });
      }
    },
    { passive: false }
  );
}
let reloadTimer = null;

function hardReload() {
  sessionStorage.setItem("fullscreen_scroll_pos", window.scrollY);


  window.location.reload();
}

document.addEventListener("fullscreenchange", () => {
  clearTimeout(reloadTimer);

  reloadTimer = setTimeout(() => {
    hardReload();
  }, 500);
});

/* F11 FALLBACK (some browsers don't reliably trigger fullscreenchange timing) */
document.addEventListener("keydown", (e) => {
  if (e.key === "F11") {
    clearTimeout(reloadTimer);

    reloadTimer = setTimeout(() => {
      hardReload();
    }, 100);
  }
});

